<idea-plugin>
    <id>com.example.xlsxgrid</id>
    <name>XLSX Grid Viewer</name>
    <vendor>example</vendor>

    <description><![CDATA[
        Opens <code>.xlsx</code> / <code>.xls</code> spreadsheets in a fast, read-only grid viewer
        inside Rider — vim-style navigation, column/regex filters, and frozen header rows. Reads
        large multi-sheet workbooks with Apache POI (streaming); it does not modify files.
    ]]></description>

    <!-- Frontend-only plugin: the platform module is enough. It loads in Rider (and any
         other IntelliJ-based IDE). The plugin name / version / since-build are injected
         from build.gradle.kts by the IntelliJ Platform Gradle Plugin. -->
    <depends>com.intellij.modules.platform</depends>

    <!-- Contribute refs.json-authoring tools to the IDE's integrated MCP server (2025.2+). Optional, so
         the viewer still loads on IDEs without / with a disabled MCP server. -->
    <depends optional="true" config-file="mcp-tools.xml">com.intellij.mcpServer</depends>

    <!-- Compose + Jewel are bundled with the IDE; declare the modules so the plugin's class loader
         can see them at runtime (compile classpath comes from bundledLibrary in build.gradle.kts). -->
    <dependencies>
        <module name="intellij.libraries.skiko"/>
        <module name="intellij.libraries.compose.runtime.desktop"/>
        <module name="intellij.libraries.compose.foundation.desktop"/>
        <module name="intellij.platform.compose"/>
        <module name="intellij.platform.jewel.foundation"/>
        <module name="intellij.platform.jewel.ui"/>
        <module name="intellij.platform.jewel.ideLafBridge"/>
    </dependencies>

    <extensions defaultExtensionNs="com.intellij">
        <!-- Treat .xlsx/.xls as a binary file type routed to our editor (not a generic archive). -->
        <fileType
            name="Excel Spreadsheet"
            implementationClass="com.example.xlsx.XlsxFileType"
            fieldName="INSTANCE"
            extensions="xlsx;xls"/>

        <!-- The custom grid editor for .xlsx / .xls files (read-only viewer). -->
        <fileEditorProvider implementation="com.example.xlsx.XlsxFileEditorProvider"/>

        <!-- Relationship view: table-level ER map, record-level lineage explorer, and integrity check. -->
        <toolWindow id="관계도" anchor="right" factoryClass="com.example.xlsx.RefGraphToolWindow"/>

        <!-- Balloons from the relationship feature (refs.json draft generation, etc.). -->
        <notificationGroup id="관계도" displayType="BALLOON"/>
    </extensions>

    <actions>
        <!-- Designate the selected folder as a game-data root (per-checkout) and infer a refs.json draft
             from the data under it. Available on the Tools menu and the Project-view folder context menu. -->
        <action id="com.example.xlsx.GenerateRefsAction"
                class="com.example.xlsx.GenerateRefsAction"
                text="데이터 루트로 지정 (refs.json 생성)"
                description="Mark this folder as a game-data root and infer a refs.json relationship-schema draft from the data under it">
            <add-to-group group-id="ToolsMenu" anchor="last"/>
            <add-to-group group-id="ProjectViewPopupMenu" anchor="last"/>
        </action>
    </actions>
</idea-plugin>
