# Gradle / build output (any module level). Release ZIPs go to GitHub Releases, not the repo.
.gradle/
.kotlin/
build/
out/
!gradle/wrapper/gradle-wrapper.jar

# IntelliJ Platform plugin sandbox + caches — large (GBs), machine-specific. MUST be ignored.
.intellijPlatform/

# Large load-test datasets (generated; never commit — GitHub blocks >100MB files)
samples/loadtest-*

# Local sample/test-output logs dropped at the repo root (NOT the tracked samples/ data)
/sample-logs/

# IDE
.idea/
*.iml
*.ipr
*.iws

# OS
.DS_Store
Thumbs.db

# Local MCP client config — points Claude Code at this machine's running JetBrains IDE
# (loopback SSE, http://127.0.0.1:64342/sse). Per-machine; not portable.
.mcp.json
